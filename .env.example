GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require

# Upstash Redis — rate limiting (anon 3/day, auth 20/day).
# Leave blank in local dev to skip rate limiting (fail-open, logs a warning).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here
